{
  "manifest_version": 3,
  "name": "Quran Progress Updater",
  "version": "1.7.0",
  "description": "Select Quran Ayah and update Todoist with detailed metadata.",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "options_page": "options.html",
  "host_permissions": [
    "https://quran.com/*",
    "https://api.todoist.com/*",
    "https://api.alquran.cloud/*"
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_title": "Activate Ayah Selector",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://quran.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
