{
  "manifest_version": 3,
  "name": "Quran Progress Updater",
  "version": "1.1",
  "description": "Select Quran Ayah and update Todoist with detailed metadata.",
  "permissions": ["scripting", "activeTab", "storage"],
  "options_page": "options.html",
  "host_permissions": [
    "https://quran.com/*",
    "https://api.todoist.com/*",
    "https://api.alquran.cloud/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Activate Ayah Selector",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["https://quran.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}